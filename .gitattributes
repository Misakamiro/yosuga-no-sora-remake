# Development metadata uses deterministic LF endings.
/.gitattributes text eol=lf
/.gitignore text eol=lf
*.md text eol=lf
*.ps1 text eol=lf

# The project contains legacy-encoded KiriKiri/TJS assets. Preserve bytes on
# Windows even when global core.autocrlf is enabled.
*.tjs -text
*.ks -text
*.cf -text
*.csv -text
*.sli -text
*.ctx -text
*.txt -text
*.extraction_script -text
*.bak -text
*.corrupted -text

# Generated inventory metadata is maintained as normalized text.
/docs/asset_manifest.csv text eol=lf
/docs/inventory/*.csv text eol=lf

# Binary runtime and media assets are versioned through Git LFS.
*.tlg filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
*.bmp filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.webp filter=lfs diff=lfs merge=lfs -text
*.psd filter=lfs diff=lfs merge=lfs -text
*.ico filter=lfs diff=lfs merge=lfs -text
*.ogg filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text
*.mpg filter=lfs diff=lfs merge=lfs -text
*.mpeg filter=lfs diff=lfs merge=lfs -text
*.avi filter=lfs diff=lfs merge=lfs -text
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.tft filter=lfs diff=lfs merge=lfs -text
*.xp3 filter=lfs diff=lfs merge=lfs -text
*.dll filter=lfs diff=lfs merge=lfs -text
*.exe filter=lfs diff=lfs merge=lfs -text
