var argNewGame = false;
var args = System.getArgument("-newgame");
if(args !== void) argNewGame = true;

win.bringToFront();

global.game = new SceneManager(win);

if(argNewGame)
{
	// 使用定时器延迟执行 ADV 场景切换，确保在主循环启动后执行
	var timer = new Timer(function() {
		Debug.message("Timer triggered, changing to ADV scene...");
		game.changeScene(SCENE_ADV, true, %[scenario:"00_z000"]);
		Debug.message("changeScene called");
	}, "");
	timer.interval = 100;
	timer.enabled = true;
}
else
{
	game.changeScene(SCENE_LOGO);
}

// 阻止定时器触发
game._sceneChangeTimer.enabled = false;
delete boot;